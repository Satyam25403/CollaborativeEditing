# Copy this to .env and fill in your values

# MongoDB
MONGO_URI=mongodb://localhost:27017/collabedit

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this

# Server
PORT=4000
CLIENT_URL=http://localhost:5173

# File uploads (local disk, swap for S3 keys later)
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50
