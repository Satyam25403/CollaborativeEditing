{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run CollabCode Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/src/**/*.js"],
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}